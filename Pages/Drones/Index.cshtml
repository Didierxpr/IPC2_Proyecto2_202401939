@page
@model IPC2_Proyecto2_202401939.Pages.Drones.IndexModel
@{
    ViewData["Title"] = "Listado de drones";
}

<h2>Listado de drones</h2>

@if (Model.Drones.Length == 0)
{
    <p>No hay drones registrados.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Nombre</th>
            </tr>
        </thead>
        <tbody>
        @for (int i = 0; i < Model.Drones.Length; i++)
        {
            <tr>
                <td>@(i + 1)</td>
                <td>@Model.Drones[i].Nombre</td>
            </tr>
        }
        </tbody>
    </table>
}
